          Buy me a coffee
        </a>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="mb-10">
      <h2 class="mb-4 text-2xl font-bold">Tech Stack</h2>
      <div class="rounded-lg border border-border bg-surface p-6">
        <div class="grid grid-cols-2 gap-4 text-sm text-text-secondary">
          <div class="flex items-center gap-2">
            <span class="font-semibold text-text-primary">Framework</span>
            <span>Astro</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="font-semibold text-text-primary">Styling</span>
            <span>Tailwind CSS</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="font-semibold text-text-primary">Deploy</span>
            <span>GitHub Pages</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="font-semibold text-text-primary">CI/CD</span>
            <span>GitHub Actions</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Source Code -->
    <section>
      <div class="rounded-lg border border-border bg-surface p-6 text-center">
        <p class="mb-3 text-text-secondary">
          このプロジェクトはオープンソースです
        </p>
        <a
          href="https://github.com/m96-chan/ai_research_dashboard"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-border px-6 py-3 font-semibold text-text-primary no-underline transition-colors hover:bg-surface-hover"
        >
