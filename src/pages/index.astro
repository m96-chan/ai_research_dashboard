---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PaperCard from '../components/PaperCard.astro';
import ModelCard from '../components/ModelCard.astro';
import RepoCard from '../components/RepoCard.astro';
import NewsCard from '../components/NewsCard.astro';
import TrendCard from '../components/TrendCard.astro';
import StockTable from '../components/StockTable.astro';

// Load data files - these are generated by the fetch scripts
let arxivData: any = { papers: [], updatedAt: '' };
let hfData: any = { models: { items: [] }, datasets: { items: [] }, updatedAt: '' };
let githubData: any = { repos: [], updatedAt: '' };
let rssData: any = { categories: [], updatedAt: '' };
let trendsData: any = { regions: [], updatedAt: '' };
let stocksData: any = { categories: [], updatedAt: '' };

try { arxivData = await import('../data/arxiv.json'); } catch {}
try { hfData = await import('../data/huggingface.json'); } catch {}
try { githubData = await import('../data/github.json'); } catch {}
try { rssData = await import('../data/rss.json'); } catch {}
try { trendsData = await import('../data/trends.json'); } catch {}
try { stocksData = await import('../data/stocks.json'); } catch {}

const papers = arxivData.papers?.slice(0, 12) ?? [];
const models = hfData.models?.items?.slice(0, 12) ?? [];
const datasets = hfData.datasets?.items?.slice(0, 8) ?? [];
const repos = githubData.repos?.slice(0, 12) ?? [];
const rssCategories = rssData.categories ?? [];
const trendRegions = trendsData.regions ?? [];
const stockCategories = stocksData.categories ?? [];
---

<Layout title="AI Research Dashboard">
  <!-- Hero -->
  <div class="mb-8 text-center">
    <h1 class="mb-2 text-3xl font-bold">AI Research Dashboard</h1>
    <p class="text-text-secondary">
      Latest papers, trending models, repositories, and news — updated every hour
    </p>
  </div>

  <!-- Stock Prices -->
  {stockCategories.length > 0 && (
    <section class="mb-10" id="stocks">
      <SectionHeader title="AI Stocks" icon="💹" updatedAt={stocksData.updatedAt} />
      <div class="grid gap-6 lg:grid-cols-3">
        {stockCategories.map((cat: any) => (
          <StockTable title={cat.name} id={cat.id} stocks={cat.stocks} />
        ))}
      </div>
    </section>
  )}

  <!-- RSS Feeds by Category -->
  {rssCategories.map((cat: any) => (
    <section class="mb-10" id={`rss-${cat.id}`}>
      <SectionHeader title={cat.name} icon={cat.icon} accentClass="text-accent-rss" updatedAt={rssData.updatedAt} />
      <div class="divide-y divide-border rounded-lg border border-border bg-surface">
        {cat.items.slice(0, 15).map((item: any) => (
          <NewsCard
            title={item.title}
            link={item.link}
            description={item.description}
            pubDate={item.pubDate}
            source={item.source}
            tldr={item.tldr}
          />
        ))}
      </div>
      {cat.items.length === 0 && <p class="text-sm text-text-muted">No feeds available.</p>}
    </section>
  ))}

  <!-- Google Trends (Tech) -->
  <section class="mb-10" id="trends">
    <SectionHeader title="Tech Trends" icon="📈" accentClass="text-accent-trends" updatedAt={trendsData.updatedAt} />
    {trendRegions.length > 0 ? (
      <div class="space-y-6">
        {trendRegions.map((r: any) => (
          <div>
            <h3 class="mb-3 flex items-center gap-2 text-sm font-semibold text-text-secondary">
              <span>{r.icon}</span>
              <span>{r.label}</span>
              <span class="text-text-muted">({r.items.length})</span>
            </h3>
            {r.items.length > 0 ? (
              <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {r.items.map((t: any) => (
                  <TrendCard title={t.title} traffic={t.traffic} articles={t.articles} />
                ))}
              </div>
            ) : (
              <p class="text-sm text-text-muted">No tech trends found.</p>
            )}
          </div>
        ))}
      </div>
    ) : (
      <p class="text-sm text-text-muted">No trends data available yet.</p>
    )}
  </section>

  <!-- Divider -->
  <div class="mb-10 flex items-center gap-4">
    <div class="h-px flex-1 bg-border"></div>
    <span class="text-sm font-medium text-text-muted">For Researchers</span>
    <div class="h-px flex-1 bg-border"></div>
  </div>

  <!-- arXiv Papers -->
  <section class="mb-10" id="arxiv">
    <SectionHeader title="Latest Papers" icon="📄" accentClass="text-accent-arxiv" updatedAt={arxivData.updatedAt} />
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {papers.map((p: any) => (
        <PaperCard
          title={p.title}
          authors={p.authors}
          summary={p.summary}
          categories={p.categories}
          link={p.link}
          pdfLink={p.pdfLink}
          published={p.published}
          tldr={p.tldr}
        />
      ))}
    </div>
    {papers.length === 0 && <p class="text-sm text-text-muted">No data available yet.</p>}
  </section>

  <!-- HuggingFace Models -->
  <section class="mb-10" id="huggingface">
    <SectionHeader title="Trending Models" icon="🤗" accentClass="text-accent-hf" updatedAt={hfData.updatedAt} />
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {models.map((m: any) => (
        <ModelCard
          id={m.id}
          likes={m.likes}
          downloads={m.downloads}
          pipeline_tag={m.pipeline_tag}
          link={m.link}
        />
      ))}
    </div>
    {models.length === 0 && <p class="text-sm text-text-muted">No data available yet.</p>}
  </section>

  <!-- HuggingFace Datasets -->
  {datasets.length > 0 && (
    <section class="mb-10" id="datasets">
      <SectionHeader title="Trending Datasets" icon="📊" accentClass="text-accent-hf" />
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {datasets.map((d: any) => (
          <ModelCard
            id={d.id}
            likes={d.likes}
            downloads={d.downloads}
            pipeline_tag=""
            link={d.link}
          />
        ))}
      </div>
    </section>
  )}

  <!-- GitHub Repos -->
  <section class="mb-10" id="github">
    <SectionHeader title="Trending Repositories" icon="⭐" accentClass="text-accent-github" updatedAt={githubData.updatedAt} />
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {repos.map((r: any) => (
        <RepoCard
          fullName={r.fullName}
          description={r.description}
          stars={r.stars}
          forks={r.forks}
          language={r.language}
          topics={r.topics}
          url={r.url}
          tldr={r.tldr}
        />
      ))}
    </div>
    {repos.length === 0 && <p class="text-sm text-text-muted">No data available yet.</p>}
  </section>
</Layout>
