---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
}

const { title, description = 'AI Research Dashboard — Latest AI/ML papers, models, repos, trends and news, updated every hour.', ogType = 'website' } = Astro.props;
const base = import.meta.env.BASE_URL;
const site = 'https://ai.m96-chan.dev';
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const ogImage = `${site}/og.png`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="AI Research Dashboard" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@djsaxia" />
    <meta name="twitter:creator" content="@djsaxia" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="alternate" type="application/rss+xml" title="AI Research Dashboard" href={`${base}feed.xml`} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <header class="sticky top-0 z-50 border-b border-border bg-surface/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3">
        <a href={base} class="flex items-center gap-2 text-text-primary no-underline hover:text-text-primary">
          <span class="text-2xl">🔭</span>
          <span class="text-lg font-bold">AI Research Dashboard</span>
        </a>
        <nav class="flex items-center gap-4 text-sm">
          <a href={base} class="text-text-secondary hover:text-text-primary">Dashboard</a>
          <a href={`${base}about`} class="text-text-secondary hover:text-text-primary">About</a>
          <a href="https://github.com/m96-chan/ai_research_dashboard/issues/new" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-text-primary" title="Feature Request">
            📮
          </a>
          <a href="https://www.buymeacoffee.com/m96chan" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-text-primary" title="Buy me a coffee">
            ☕
          </a>
          <a href={`${base}feed.xml`} class="text-text-secondary hover:text-text-primary" title="RSS Feed">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
          </a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-6">
      <slot />
    </main>

    <footer class="border-t border-border py-6 text-center text-sm text-text-muted">
      <div class="mx-auto max-w-7xl px-4">
        Updated automatically every hour via GitHub Actions
      </div>
    </footer>
  </body>
</html>
