---
interface Props {
  id: string;
  likes: number;
  downloads: number;
  pipeline_tag: string;
  link: string;
}

const { id, likes, downloads, pipeline_tag, link } = Astro.props;

function formatNum(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(1)}K`;
  return n.toString();
}
---

<a href={link} target="_blank" rel="noopener noreferrer"
   class="group block rounded-lg border border-border bg-surface p-4 transition-colors hover:bg-surface-hover no-underline">
  <div class="mb-2 flex items-start justify-between gap-2">
    <h3 class="text-sm font-semibold text-text-primary group-hover:text-accent-hf truncate">
      {id}
    </h3>
  </div>
  {pipeline_tag && (
    <span class="mb-2 inline-block rounded-full bg-accent-hf/20 px-2 py-0.5 text-xs text-accent-hf">
      {pipeline_tag}
    </span>
  )}
  <div class="flex items-center gap-4 text-xs text-text-muted">
    <span title="Likes">♥ {formatNum(likes)}</span>
    <span title="Downloads">↓ {formatNum(downloads)}</span>
  </div>
</a>
