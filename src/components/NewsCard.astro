---
interface Props {
  title: string;
  link: string;
  description: string;
  pubDate: string;
  source: string;
  tldr?: string;
}

const { title, link, pubDate, source, tldr } = Astro.props;

const date = pubDate
  ? new Date(pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
  : '';
---

<a href={link} target="_blank" rel="noopener noreferrer"
   class="group flex items-start gap-3 rounded-md px-3 py-2 transition-colors hover:bg-surface-hover no-underline">
  <span class="mt-0.5 shrink-0 rounded bg-accent-rss/15 px-1.5 py-0.5 text-[10px] font-medium text-accent-rss min-w-[80px] text-center truncate">
    {source}
  </span>
  <span class="min-w-0 flex-1">
    <span class="block truncate text-sm text-text-primary group-hover:text-accent-rss">
      {title}
    </span>
    {tldr && (
      <span class="block mt-0.5 text-xs text-text-muted leading-snug line-clamp-1">
        {tldr}
      </span>
    )}
  </span>
  {date && <span class="mt-0.5 shrink-0 text-xs text-text-muted">{date}</span>}
</a>
